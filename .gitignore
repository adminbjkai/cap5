# ==========================================
# CAP5 — Git Ignore
# ==========================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
out/
*.tsbuildinfo

# Source maps (generated during build)
*.map

# Environment files — exclude all .env* everywhere except .env.example
**/.env
**/.env.local
**/.env.development
**/.env.production
**/.env.test
**/.env.*.local
*.local
!**/.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing
coverage/
.nyc_output/
playwright-report/
test-results/

# IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.cursor/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Cache
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# Temporary files
tmp/
temp/
*.tmp

# ==========================================
# Package Manager Specific
# ==========================================

# pnpm
.pnpm-store/

# ==========================================
# Service Specific
# ==========================================

# Media server uploads (if local dev uses filesystem)
apps/media-server/uploads/

# Worker processing temp files
apps/worker/tmp/

# ==========================================
# CAP5 — files not for the public repo
# ==========================================

# AI agent audit artifacts
.audit/
bykimi.md
/AGENTS.md

# AI agent session directories
.claude/
.gemini/

# Reference copies / legacy
cap4_new/
cap4/
Cap_for_reference_only/
nanobanana/

# npm lockfile (project uses pnpm)
package-lock.json
**/package-lock.json

# Dev sample files
sample_videos/

# Runtime logs (use docker logs instead)
logs/

# Temp scripts
run-me.sh
start-cap3.sh
stop-cap3.sh

# Productivity plugin memory (local only)
memory/
