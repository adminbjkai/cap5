{
  "name": "@cap/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm -w build:internal",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.997.0",
    "@cap/config": "workspace:*",
    "@cap/db": "workspace:*",
    "@cap/logger": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  }
}
