{
  "name": "cap5",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "bash scripts/dev-local.sh",
    "dev:web-api": "pnpm --filter @cap/web-api dev",
    "dev:web": "pnpm --filter @cap/web dev",
    "dev:worker": "pnpm --filter @cap/worker dev",
    "dev:media-server": "pnpm --filter @cap/media-server dev",
    "build:internal": "pnpm --filter @cap/config --filter @cap/db --filter @cap/logger build",
    "build": "pnpm --filter '*' build",
    "build:all": "pnpm build:internal && pnpm --filter '*' build",
    "clean": "find . -name 'dist' -not -path '*/node_modules/*' -type d -exec rm -rf {} + 2>/dev/null; find . -path '*/node_modules/.cache' -type d -exec rm -rf {} + 2>/dev/null; echo 'Clean done.'",
    "pretypecheck": "pnpm build:internal",
    "pretest": "pnpm build:internal",
    "test": "pnpm --filter '*' test",
    "test:all": "pnpm pretest && pnpm --filter '*' test",
    "test:integration": "pnpm --filter @cap/web-api test:integration",
    "test:e2e": "pnpm --filter @cap/web-api test:e2e",
    "lint": "pnpm --filter '*' lint",
    "lint:fix": "pnpm --filter '*' lint:fix",
    "typecheck": "pnpm --filter '*' typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "pnpm --filter @cap/db migrate",
    "up": "docker compose up -d --build",
    "down": "docker compose down",
    "logs": "docker compose logs -f --tail=200",
    "migrate": "docker compose run --rm migrate",
    "reset-db": "docker compose down -v && docker compose up -d --build",
    "smoke": "curl -fsS http://localhost:3000/health && curl -fsS http://localhost:3000/ready"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^25.3.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  }
}
